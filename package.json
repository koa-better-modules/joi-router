  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koa-better-modules/joi-router.git"
  },
  "bugs": {
    "url": "https://github.com/koa-better-modules/joi-router/issues"
  },
  "homepage": "https://github.com/koa-better-modules/joi-router",
  "dependencies": {
    "@fastify/busboy": "^3.2.0",
    "@koa/router": "^15.3.0",
    "clone": "^2.1.2",
    "co-body": "^6.2.0",
    "debug": "^4.4.3",
    "is-generator-function": "^1.1.2",
    "joi": "^18.0.2"
  },
  "devDependencies": {
    "@types/co-body": "^6.1.3",
    "@types/koa": "^3.0.1",
    "@types/node": "^25.3.2",
    "eslint": "^8.57.1",
    "koa": "^3.1.2",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3"
  },
  "eslintConfig": {
    "extends": [
